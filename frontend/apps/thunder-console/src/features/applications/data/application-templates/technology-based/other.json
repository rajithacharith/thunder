{
  "id": "other",
  "displayName": "Other",
  "description": "Custom application with standard OAuth2 configuration",
  "defaults": {
    "name": "Custom Application",
    "inboundAuthConfig": [
      {
        "type": "oauth2",
        "config": {
          "grantTypes": ["authorization_code", "refresh_token"],
          "responseTypes": ["code"],
          "pkceRequired": true,
          "tokenEndpointAuthMethod": "none",
          "publicClient": true
        }
      }
    ]
  }
}
