{
  "id": "mcp-client",
  "displayName": "MCP Client",
  "description": "AI model client using the Model Context Protocol",
  "creationFlow": {
    "steps": ["NAME", "CONFIGURE"]
  },
  "defaults": {
    "name": "MCP Client Application",
    "inboundAuthConfig": [
      {
        "type": "oauth2",
        "config": {
          "grantTypes": ["authorization_code", "refresh_token"],
          "responseTypes": ["code"],
          "redirectUris": [],
          "pkceRequired": true,
          "tokenEndpointAuthMethod": "none",
          "publicClient": true
        }
      }
    ],
    "allowedUserTypes": []
  }
}
